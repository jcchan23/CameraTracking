{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": false,
    "allowJs": true,
    "skipLibCheck": true,
    "baseUrl": "."
  },
  "include": [
    "**/*.uts",
    "**/*.uvue",
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "unpackage",
    "dist"
  ]
}
